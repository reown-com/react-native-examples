{
  "expo": {
    "name": "React N. Wallet",
    "slug": "rn-web3wallet",
    "version": "1.0.0",
    "scheme": "rn-web3wallet",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.walletconnect.web3wallet.rnsample",
      "buildNumber": "158",
      "appleTeamId": "W5R8AG9K22",
      "config": {
        "usesNonExemptEncryption": false
      },
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:appkit-lab.reown.com",
        "applinks:lab.reown.com",
        "applinks:pay.walletconnect.com",
        "applinks:staging.pay.walletconnect.com",
        "applinks:dev.pay.walletconnect.com"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Our app does not request this permission or utilize this functionality but it is included in our info.plist since our app utilizes the react-native-permissions library."
      }
    },
    "android": {
      "package": "com.walletconnect.web3wallet.rnsample",
      "versionCode": 73,
      "permissions": ["android.permission.POST_NOTIFICATIONS"],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [{ "scheme": "wc" }]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            { "scheme": "https", "host": "appkit-lab.reown.com", "pathPrefix": "/rn_walletkit" },
            { "scheme": "https", "host": "lab.reown.com", "pathPrefix": "/rn_walletkit" }
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            { "scheme": "https", "host": "pay.walletconnect.com" },
            { "scheme": "https", "host": "staging.pay.walletconnect.com" },
            { "scheme": "https", "host": "dev.pay.walletconnect.com" }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-bootsplash",
        {
          "assetsDir": "assets/bootsplash",
          "android": { "parentTheme": "EdgeToEdge", "darkContentBarsStyle": false }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow access to the camera to scan codes",
          "enableCodeScanner": true
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "This app requires NFC to send messages",
          "includeNdefEntitlement": false
        }
      ],
      [
        "expo-navigation-bar",
        { "enforceContrast": false }
      ],
      "react-native-bottom-tabs",
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "walletconnect",
          "project": "w3w-react-native"
        }
      ],
      "./plugins/withAndroidVariants.js",
      "./plugins/withAndroidVariantIcons.js"
    ]
  }
}
