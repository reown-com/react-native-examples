{
  "name": "RNWeb3Wallet",
  "version": "1.0.0",
  "private": true,
  "main": "index",
  "scripts": {
    "postinstall": "./scripts/copy-sample-files.sh",
    "prebuild": "expo prebuild",
    "postprebuild": "node scripts/setup-secrets.js",
    "android": "expo run:android",
    "android:debug": "expo run:android --app-id com.walletconnect.web3wallet.rnsample.debug",
    "android:internal": "expo run:android --variant internal --app-id com.walletconnect.web3wallet.rnsample.internal",
    "android:prod": "expo run:android --variant release --app-id com.walletconnect.web3wallet.rnsample",
    "android:build": "cd android && ./gradlew app:assembleRelease",
    "android:build:internal": "cd android && ./gradlew app:assembleInternal",
    "android:build:debug": "cd android && ./gradlew app:assembleDebug",
    "ios": "expo run:ios",
    "ios:debug": "APP_VARIANT=debug expo run:ios",
    "ios:internal": "APP_VARIANT=internal expo run:ios",
    "ios:prod": "APP_VARIANT=production expo run:ios",
    "start": "expo start",
    "web": "expo start --web",
    "web:export": "expo export --platform web",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "e2e": "maestro test ../../.maestro",
    "e2e:studio": "maestro studio",
    "e2e:upload": "maestro cloud ./android/app/build/outputs/apk/release/app-release.apk .maestro",
    "permit2:revoke": "node ./scripts/revoke-permit2-approval.js"
  },
