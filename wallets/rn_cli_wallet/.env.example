# create .env
# These EXPO_PUBLIC_* vars are auto-loaded by the Expo CLI and inlined into the
# JS bundle at build time. They are PUBLIC (embedded in the bundle) — no secrets.

EXPO_PUBLIC_PROJECT_ID='39bc93c...'
EXPO_PUBLIC_SENTRY_DSN=''
EXPO_PUBLIC_TON_CENTER_API_KEY=''
EXPO_PUBLIC_BLOCKCHAIN_API_URL=''
EXPO_PUBLIC_TEST_PRIVATE_KEY=''
EXPO_PUBLIC_TEST_MODE=''
# Override the WCPay API base URL — leave blank to use walletkit's default.
EXPO_PUBLIC_PAY_API_BASE_URL=''

# Build-time only (read by the Sentry gradle/xcode plugins, not by the JS bundle)
SENTRY_DISABLE_AUTO_UPLOAD=true
