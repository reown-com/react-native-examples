{
  "name": "pos-app",
  "main": "index",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:pos": "expo run:android --port 8082",
    "android:build": "cd android && ./gradlew assembleRelease",
    "prebuild": "expo prebuild",
    "postprebuild": "node scripts/setup-secrets.js",
    "postinstall": "patch-package && npm run web:setup",
    "ios": "expo run:ios",
    "web": "npm run web:setup && expo start --web",
    "web:serve": "npm run web:setup && expo serve",
    "web:build": "npm run web:setup && expo export -p web",
    "web:setup": "npx setup-skia-web && mkdir -p public && cp web/static/js/canvaskit.wasm public/",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check .",
    "lint": "expo lint",
    "test": "jest"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.11.0",
    "@shopify/react-native-skia": "2.4.18",
    "@tanstack/react-query": "^5.90.11",
    "@walletconnect/safe-json": "^1.0.2",
    "expo": "^55.0.0",
    "expo-application": "~55.0.8",
    "expo-asset": "~55.0.7",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.8",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.5",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-router": "~55.0.2",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "pressto": "0.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.65.0",
    "react-native": "0.84.0",
    "react-native-device-info": "^14.1.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-mmkv": "^4.0.0",
    "react-native-nitro-modules": "^0.31.5",
    "react-native-permissions": "^5.4.4",
    "react-native-qrcode-skia": "^0.3.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-thermal-pos-printer": "^1.6.6",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.10",
    "@vercel/node": "5.5.16",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.6.2",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "hono": "4.11.7",
    "tar": "7.5.8",
    "node-forge": "1.3.3",
    "glob": "10.5.0",
    "js-yaml": "4.1.1",
    "esbuild": "0.25.0",
    "@vercel/node": {
      "undici": "5.29.0"
    },
    "minimatch": "9.0.6"
  },
  "private": true
}
