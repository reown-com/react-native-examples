# create .env
# EXPO_PUBLIC_* vars are auto-loaded by the Expo CLI and inlined into the JS
# bundle at build time. They are PUBLIC (embedded in the bundle) — no secrets.

EXPO_PUBLIC_PROJECT_ID='YOUR_PROJECT_ID'
EXPO_PUBLIC_SENTRY_DSN=''

# Build-time only (read by the Sentry gradle/xcode plugins, not the JS bundle)
SENTRY_DISABLE_AUTO_UPLOAD=true
SENTRY_AUTH_TOKEN=""
