# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"

default_platform(:ios)

platform :ios do

  lane :release_testflight do |options|
    # Setup the keychain and match to work with CI
    setup_ci()

    project_type = ENV['PROJECT_TYPE'] || ENV['SCHEME']
    branch_name = ENV['BRANCH_NAME'] || ''

    # Get Apple API Key
    api_key = app_store_connect_api_key(
      key_id: ENV["APPLE_KEY_ID"],
      issuer_id: ENV["APPLE_ISSUER_ID"],
      key_content: ENV["APPLE_KEY_CONTENT"],            
      duration: 1200,            
      in_house: false,
    )

    # Sync certificates
    match(
      readonly: false,
      type: "appstore",
      app_identifier: ENV['BUNDLE_ID'],
      git_url: ENV['MATCH_GIT_URL'],
      git_basic_authorization: options[:token],
      api_key: api_key,
      include_all_certificates: true,
      force_for_new_devices: true,
      force_for_new_certificates: true
    )

    # Update Xcode project code signing settings to use Match profiles
    update_code_signing_settings(
      use_automatic_signing: false,
      path: ENV['XCODE_PROJECT_PATH'],
      bundle_identifier: ENV['BUNDLE_ID'],
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore #{ENV['BUNDLE_ID']}"
    )

    # Install pods (skip repo_update if cache hit)
    cocoapods(
      clean_install: false,
      repo_update: ENV['PODS_CACHE_HIT'] != 'true',
      podfile: ENV['PODFILE_PATH']
    )

    # Get latest build number
    number = latest_testflight_build_number(
      app_identifier: ENV["BUNDLE_ID"],
      username: options[:username],
    )

    # Increment build number
    increment_build_number(
      build_number: number + 1,
      xcodeproj: ENV['XCODE_PROJECT_PATH']
    )

    # Build app
    gym(
      configuration: "Release",
      workspace: ENV['XCWORKSPACE_PATH'],
      scheme: ENV['SCHEME'],
      export_method: "app-store",
      output_directory: "./build",
      output_name: "#{ENV['PROJECT_TYPE']}-#{ENV['RELEASE_TYPE']}.ipa"
    )

    testflight_params = {
      apple_id: ENV["APPLE_ID"],
      app_identifier: ENV["BUNDLE_ID"],
      changelog: "#{project_type} build from branch: #{branch_name}",
      skip_waiting_for_build_processing: true
    }
    
    if ENV['TESTFLIGHT_GROUPS'] && !ENV['TESTFLIGHT_GROUPS'].empty?
      testflight_params[:distribute_external] = true
      testflight_params[:notify_external_testers] = true
      testflight_params[:groups] = ENV['TESTFLIGHT_GROUPS'].split(',').map(&:strip)
    end

    # Upload to TestFlight
    upload_to_testflight(testflight_params)

    # Only clean artifacts when running locally (not in CI)
    clean_build_artifacts() unless ENV['CI']
  end

  lane :build_for_simulator do |options|

    # Install pods (skip repo_update if cache hit)
    cocoapods(
      clean_install: false,
      repo_update: ENV['PODS_CACHE_HIT'] != 'true',
      podfile: ENV['PODFILE_PATH']
    )

    # Build .app directly for simulator — no archive, no IPA, no signing
    gym(
      workspace: ENV['XCWORKSPACE_PATH'],
      scheme: ENV['SCHEME'],
      configuration: "Release",
      destination: "generic/platform=iOS Simulator",
      derived_data_path: "./build/derived_data",
      skip_codesigning: true,
      skip_package_ipa: true,
      skip_archive: true,
    )

    # Find the .app in derived data and record its path
    app_path = Dir.glob("./build/derived_data/Build/Products/Release-iphonesimulator/*.app").first
    UI.user_error!("Could not find .app in derived data") unless app_path

    sh("mkdir -p ./build")
    File.write("./build/app_path.txt", File.expand_path(app_path))
    UI.success("✅ Simulator .app: #{File.expand_path(app_path)}")
  end

  lane :test_code_signing do
    ENV['XCODE_PROJECT_PATH'] = 'dapps/pos-app/ios/WPay.xcodeproj'
    ENV['BUNDLE_ID'] = 'com.reown.mobilepos'
    
    update_code_signing_settings(
      use_automatic_signing: false,
      path: ENV['XCODE_PROJECT_PATH'],
      bundle_identifier: ENV['BUNDLE_ID'],
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore #{ENV['BUNDLE_ID']}"
    )
    
    puts "✅ Code signing settings updated successfully!"
    puts "Profile name used: match AppStore #{ENV['BUNDLE_ID']}"
  end

end
